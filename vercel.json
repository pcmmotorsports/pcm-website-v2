{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/settle-sweep",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/anomaly-alert",
      "schedule": "0 1 * * *"
    }
  ]
}
