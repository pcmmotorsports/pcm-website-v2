{
  "name": "@pcm/storefront",
  "version": "0.0.0",
  "private": true,
  "description": "PCM 前台(Next.js 16 + Tailwind v4)— 殼、待後續 slice 裝框架",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
